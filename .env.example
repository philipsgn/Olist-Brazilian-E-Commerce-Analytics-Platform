# =============================================================================
# E-commerce Data Pipeline - Environment Variables Template
# Copy this file to .env and fill in the actual values.
# =============================================================================

# --- Database (Local/Docker) ---
POSTGRES_USER=de_user
POSTGRES_PASSWORD=de_password
POSTGRES_DB=ecommerce_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# --- Airflow Core ---
AIRFLOW_UID=1000
ENVIRONMENT=dev  # dev or prod

# --- Monitoring & Alerting (Discord) ---
# IMPORTANT: DO NOT commit your actual Webhook URL to git!
DISCORD_WEBHOOK_URL=your_discord_webhook_url_here

# --- AWS RDS (Production) ---
RDS_HOST=your-rds-endpoint.amazonaws.com
RDS_USER=db_admin
DBT_ENV_SECRET_RDS_PASSWORD=your_rds_password
RDS_DBNAME=ecommerce_db

# --- AWS S3 (Data Lake) ---
S3_BUCKET=your-bucket-name
USE_S3=false
