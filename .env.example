POSTGRES_USER=de_user
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=ecommerce_db
POSTGRES_PORT=5433

REDIS_PORT=6379

AIRFLOW_DB_URI=postgresql+psycopg2://de_user:de_password@postgres:5432/airflow
AIRFLOW_CELERY_BROKER_URL=redis://redis:6379/0
AIRFLOW_CELERY_RESULT_BACKEND=db+postgresql://de_user:de_password@postgres:5432/airflow
AIRFLOW_FERNET_KEY=CHANGE_ME_RUN: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW_WEBSERVER_SECRET_KEY=CHANGE_ME_RANDOM_STRING
AIRFLOW_WEBSERVER_PORT=8080
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD
AIRFLOW_ADMIN_EMAIL=admin@example.com
AIRFLOW_ADMIN_FIRSTNAME=Admin
AIRFLOW_ADMIN_LASTNAME=User

SUPERSET_PORT=8088
SUPERSET_SECRET_KEY=CHANGE_ME_RANDOM_STRING
